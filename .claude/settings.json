{
  "permissions": {
    "allow": [
      "Bash(python manage.py:*)",
      "Bash(pytest:*)",
      "Bash(uv run pytest:*)",
      "Bash(inv ruff:*)",
      "Bash(ruff:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(uv pip list:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(npm run build:*)",
      "Bash(npm run type-check:*)",
      "Bash(npx stencil test:*)",
      "WebFetch(domain:docs.openchatstudio.com)",
      "Bash(npm run lint:*)",
      "Bash(uv run ruff check:*)",
      "Bash(uv run ruff format:*)"
    ]
  },
  "enableAllProjectMcpServers": false,
  "extraKnownMarketplaces": {
    "dimagi-claude-workflows": {
      "source": {
        "source": "github",
        "repo": "dimagi/dimagi-claude-workflows"
      }
    }
  },
  "enabledPlugins": {
    "dev-utils@dimagi-claude-workflows": true
  },
  "env": {
    "MAX_THINKING_TOKENS": "32000"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/setup-env.sh"
          }
        ]
      }
    ]
  }
}
